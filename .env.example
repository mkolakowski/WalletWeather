# Copy to .env and fill in. Do NOT commit .env.

# Postgres password (any strong random string)
DB_PASSWORD=change_me_to_something_strong

# Session cookie secret (random 32+ chars)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=replace_with_random_string

# Field encryption key (Fernet key, urlsafe base64 32 bytes)
# Generate: python3 -c "import base64, secrets; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=replace_with_fernet_key

# --- Optional: Google OAuth ---
# Leave both blank to use local email/password login only.
# To enable Google sign-in, create OAuth credentials at
# https://console.cloud.google.com/apis/credentials with redirect URI:
#   ${APP_BASE_URL}/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public URL where the app is reachable (used to build the OAuth redirect)
APP_BASE_URL=http://localhost:8300

# Set to "false" to disable new account self-registration after you've created
# your initial users. Existing users can still sign in.
ALLOW_REGISTRATION=true

# Optional: comma-separated allowlist of emails permitted to register/sign in.
# Applies to BOTH local registration and Google OAuth. Leave blank to allow any email.
ALLOWED_EMAILS=

# Optional: comma-separated list of admin emails. Admins get access to the
# Admin panel for user management, system backups, and permission overrides.
ADMIN_EMAILS=

# Demo mode. When "true" (the default), the app boots with a pre-seeded
# admin user (admin@demo.walletweather.local / demo1234) and sample
# accounts, recurring transactions, and actual postings so you can click
# around immediately.
# Set to "false" for real use. On the next start, the demo user and ALL
# data owned by any @demo.walletweather.local user is deleted. Accounts
# you created for yourself are never touched.
DEMO_MODE=true
